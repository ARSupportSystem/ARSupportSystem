# Application display name used in API docs and health checks.
APP_NAME="AR Support System"

# Runtime environment: use "development" locally and "production" in deployment.
ENV="development"

# JWT signing secret. Must be a long, random value in production.
SECRET_KEY="change-this-to-a-long-random-secret-key-in-production"

# JWT signing algorithm.
ALGORITHM="HS256"

# Access token lifetime in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Login endpoint rate limit applied per client IP.
RATE_LIMIT_LOGIN="5/minute"

# Number of failed login attempts per IP before brute-force suspicion is logged.
MAX_FAILED_LOGINS=5

# Sliding window (minutes) for failed login counting.
FAILED_LOGIN_WINDOW_MINUTES=10

# SQLAlchemy database URL.
DATABASE_URL="sqlite:///./ar_support.db"

# Comma-separated list of allowed CORS origins.
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# Optional TLS certificate path for HTTPS when running backend directly.
HTTPS_CERT_FILE=

# Optional TLS private key path for HTTPS when running backend directly.
HTTPS_KEY_FILE=
